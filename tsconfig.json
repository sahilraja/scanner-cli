{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2022", "dom"],
    "outDir": "dist",
    "rootDir": ".",
    "strict": false,
    "esModuleInterop": true,
    "declaration": true,
    "skipLibCheck": true,
    "noEmitOnError": false,
    "noUncheckedIndexedAccess": false,
    "resolveJsonModule": true
  },
  "include": ["bin/**/*", "src/**/*"],
  "exclude": ["dist", "node_modules"]
}
